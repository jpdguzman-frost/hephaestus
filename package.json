{
  "name": "rex-figma",
  "version": "0.3.0",
  "description": "A stable, reliable MCP server for full read/write access to Figma's canvas",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "rex": "dist/index.js"
  },
  "scripts": {
    "build": "npm run build:server && npm run build:plugin",
    "build:server": "tsup",
    "build:plugin": "esbuild plugin/code.ts --bundle --outfile=plugin/code.js --platform=browser --target=es2017",
    "dev": "tsup --watch & esbuild plugin/code.ts --bundle --outfile=plugin/code.js --platform=browser --target=es2017 --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ && prettier --check \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^17.3.1",
    "fastify": "^5.3.3",
    "mongodb": "^7.1.0",
    "uuid": "^11.1.0",
    "ws": "^8.18.2",
    "zod": "^3.24.4",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.4",
    "eslint": "^9.27.0",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
